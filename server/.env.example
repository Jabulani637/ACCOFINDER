# PostgreSQL — get from neon.tech or supabase.com
DATABASE_URL=postgresql://user:password@host/dbname

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-a-long-random-string

# Resend — get from resend.com (free: 3000 emails/month)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@yourdomain.com

# Twilio — get from twilio.com (free trial credit)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+12015551234

# OTP Configuration
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6

# JWT Algorithm and Expiry
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email Configuration
EMAIL_PROVIDER=resend  # "resend" or "smtp"

# SMTP Configuration (if using SMTP instead of Resend)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Copy this to a .env file and fill in your real values.
# Never commit .env to GitHub — add it to .gitignore.
